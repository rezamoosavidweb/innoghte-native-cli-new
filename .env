# ── Region ───────────────────────────────────────────────────────────────────
# Set to 'ir' for the Iran build; leave blank (or omit) for international.
# Inlined at compile time — Metro must be restarted after changing this.
REACT_NATIVE_IS_DOT_IR=ir

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL for all API calls. Defaults to the staging server when unset.
REACT_NATIVE_API_URL=https://apistg.innoghte.ir

# ── Payment gateways ──────────────────────────────────────────────────────────
# Set to 'true' to enable each gateway in the donation flow.
REACT_NATIVE_IS_SHOW_ZARINPAL=true
REACT_NATIVE_IS_SHOW_VANDAR=false

# ── MMKV encryption (optional) ────────────────────────────────────────────────
# Encryption is disabled when MMKV_ENCRYPTION_KEY is blank.
# MMKV_ENCRYPTION_KEY=
# MMKV_ENCRYPTION_TYPE=AES-128
