# Copy to keystore.properties in this folder (next to build.gradle) and fill in your values.
# keystore.properties is gitignored. Never commit real passwords.
#
# Create an upload key (example; adjust paths and alias):
#   keytool -genkeypair -v -keystore app/my-upload-key.keystore -alias my-key-alias -keyalg RSA -keysize 2048 -validity 10000
#
# Paths for MYAPP_RELEASE_STORE_FILE are relative to the android/ project directory.
MYAPP_RELEASE_STORE_FILE=app/my-upload-key.keystore
MYAPP_RELEASE_KEY_ALIAS=my-key-alias
MYAPP_RELEASE_STORE_PASSWORD=your-store-password
MYAPP_RELEASE_KEY_PASSWORD=your-key-password
